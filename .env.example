# Public site URL — used for canonical links, sitemap, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://rethinkcnergy.com

# Resend (https://resend.com) — transactional email for the contact form.
# Required in production; optional in local dev (form will still persist to leads.jsonl).
RESEND_API_KEY=

# Where contact-form emails are delivered, and the From header used.
CONTACT_EMAIL_TO=parham@rethinkcnergy.com
CONTACT_EMAIL_FROM="ReTHINK CNERGY <hello@rethinkcnergy.com>"

# Directory where leads.jsonl is written. On Render, point this at a mounted disk.
# Leave unset locally to default to ./.data
LEADS_DIR=
